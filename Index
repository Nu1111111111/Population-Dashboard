<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>World Sustainability · Dashboard</title>
<style>
:root{
  --ink:#0E1A17; --paper:#EAEEEC; --panel:#FFFFFF;
  --line:#D5DCD8; --line2:#E5EAE7; --text:#15211D; --muted:#5E6E67; --faint:#8A968F;
  --accent:#0F766E; --accent-soft:#D7ECE9;
  --climate:#2E7D5B; --economy:#B7791F; --social:#2B7C8C; --education:#6B5BA6; --equality:#B0476B;
  --nodata:#C4CCC8; --grid:#EDF1EF;
  --mono:ui-monospace,"SF Mono",Menlo,Consolas,"Liberation Mono",monospace;
  --sans:system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0}
body{font-family:var(--sans);background:var(--paper);color:var(--text);-webkit-font-smoothing:antialiased;font-size:14px;line-height:1.45}
.num{font-family:var(--mono);font-variant-numeric:tabular-nums;letter-spacing:-.01em}
.app{display:grid;grid-template-columns:236px 1fr;min-height:100vh}
.side{background:var(--ink);color:#CFE0DA;position:sticky;top:0;height:100vh;display:flex;flex-direction:column;overflow:hidden}
.brand{padding:20px 20px 16px;border-bottom:1px solid #21342D}
.brand h1{font-size:15px;margin:0;letter-spacing:.02em;color:#F2F7F5;font-weight:650}
.brand .sub{font-size:11px;color:#7E948C;margin-top:4px;font-family:var(--mono)}
.nav{padding:10px;flex:1;overflow:auto}
.nav button{display:flex;align-items:center;gap:10px;width:100%;text-align:left;background:none;border:0;color:#AFC4BC;padding:9px 12px;border-radius:8px;cursor:pointer;font-size:13px;font-family:var(--sans);transition:.12s}
.nav button:hover{background:#17271F;color:#E7F1ED}
.nav button.active{background:#1C2F28;color:#fff}
.nav .dot{width:8px;height:8px;border-radius:2px;flex:none}
.nav .grp{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:#5E746C;padding:14px 12px 6px}
.side .foot{padding:14px 18px;border-top:1px solid #21342D;font-size:10.5px;color:#6C857C;font-family:var(--mono);line-height:1.5}
.main{min-width:0;display:flex;flex-direction:column}
.topbar{position:sticky;top:0;z-index:30;background:rgba(234,238,236,.93);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);padding:14px 26px}
.vtitle{font-size:20px;font-weight:650;letter-spacing:-.01em;margin:0;display:flex;align-items:center;gap:10px}
.vtitle .stripe{width:4px;height:20px;border-radius:2px}
.vsub{font-size:12px;color:var(--muted);margin-top:3px}
.content{padding:22px 26px 60px;max-width:1500px;width:100%}
.filters{display:flex;gap:14px;flex-wrap:wrap;align-items:flex-start;margin-top:14px}
.fbox{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:10px 13px;min-width:0}
.fbox .lab{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--faint);margin-bottom:7px;font-weight:600}
.yearwrap{min-width:290px}
.rangeline{display:flex;align-items:center;gap:9px}
.rangeline .num{font-size:13px;min-width:34px;text-align:center}
.dual{position:relative;height:26px;flex:1}
.dual input[type=range]{position:absolute;width:100%;margin:0;pointer-events:none;-webkit-appearance:none;background:none;top:9px;height:8px}
.dual input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;pointer-events:all;width:15px;height:15px;border-radius:50%;background:var(--accent);border:2px solid #fff;box-shadow:0 1px 3px #0003;cursor:pointer}
.dual input[type=range]::-moz-range-thumb{pointer-events:all;width:15px;height:15px;border-radius:50%;background:var(--accent);border:2px solid #fff;cursor:pointer}
.dual .track{position:absolute;top:13px;left:0;right:0;height:4px;background:var(--line);border-radius:3px}
.dual .fill{position:absolute;top:13px;height:4px;background:var(--accent);border-radius:3px}
.chips{display:flex;flex-wrap:wrap;gap:6px;max-width:430px;margin-top:8px}
.chip{display:inline-flex;align-items:center;gap:6px;background:var(--accent-soft);color:#0a534c;border:1px solid #b6dcd7;border-radius:20px;padding:3px 6px 3px 10px;font-size:12px}
.chip b{font-weight:600}
.chip button{border:0;background:#0f766e;color:#fff;width:15px;height:15px;border-radius:50%;cursor:pointer;font-size:11px;line-height:1;display:flex;align-items:center;justify-content:center;padding:0}
.selectbtn{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 11px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:7px;color:var(--text)}
.selectbtn:hover{border-color:var(--accent)}
.popover{position:absolute;z-index:50;margin-top:7px;background:#fff;border:1px solid var(--line);border-radius:11px;box-shadow:0 12px 34px #0e1a1718;width:320px;padding:11px}
.popover input.search{width:100%;border:1px solid var(--line);border-radius:7px;padding:7px 9px;font-size:13px;margin-bottom:8px;font-family:var(--sans)}
.optlist{max-height:260px;overflow:auto;margin:0;padding:0;list-style:none}
.optlist li{display:flex;align-items:center;gap:8px;padding:5px 6px;border-radius:6px;cursor:pointer;font-size:13px}
.optlist li:hover{background:var(--paper)}
.optlist li input{accent-color:var(--accent)}
.groupbtns{display:flex;flex-wrap:wrap;gap:6px}
.gbtn{border:1px solid var(--line);background:#fff;border-radius:7px;padding:5px 10px;font-size:12px;cursor:pointer;color:var(--muted)}
.gbtn:hover{border-color:var(--accent);color:var(--text)}
.gbtn.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.resetbtn{border:1px solid #d8b8b8;background:#fff;color:#9a3838;border-radius:8px;padding:8px 14px;font-size:13px;cursor:pointer;font-weight:550;align-self:flex-start}
.resetbtn:hover{background:#fbeeee}
.grid{display:grid;gap:16px}
.g-kpi{grid-template-columns:repeat(auto-fit,minmax(180px,1fr))}
.g-2{grid-template-columns:repeat(2,minmax(0,1fr))}
@media(max-width:1080px){.g-2{grid-template-columns:1fr}}
.panel{background:var(--panel);border:1px solid var(--line);border-radius:13px;padding:16px 17px;min-width:0}
.panel.span2{grid-column:1 / -1}
.phead{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:6px}
.ptitle{font-size:13.5px;font-weight:620;letter-spacing:-.005em}
.pmeta{font-size:11px;color:var(--faint);font-family:var(--mono);text-align:right;white-space:nowrap}
.punit{font-size:11px;color:var(--muted);margin-top:1px}
.kpi .v{font-size:25px;font-weight:600;margin:7px 0 2px;line-height:1.05}
.kpi .k{font-size:11.5px;color:var(--muted)}
.kpi .note{font-size:10.5px;color:var(--faint);margin-top:6px;font-family:var(--mono)}
.kpi{border-left:3px solid var(--accent)}
.nodata-tag{color:var(--faint);font-style:italic}
.cov{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:10px}
.covbar{flex:1;height:5px;background:var(--line);border-radius:3px;overflow:hidden;min-width:60px}
.covbar i{display:block;height:100%;background:var(--accent)}
.legend{display:flex;align-items:center;gap:2px;flex-wrap:wrap;margin-top:8px}
.legend .sw{width:26px;height:11px}
.legend .lt{font-size:10px;color:var(--muted);font-family:var(--mono);margin:0 6px}
.legend .litem{display:inline-flex;align-items:center;gap:5px;margin-right:12px;font-size:11px;color:var(--muted)}
.legend .litem .d{width:10px;height:10px;border-radius:50%}
.ctable{width:100%;border-collapse:collapse;font-size:12.5px}
.ctable th,.ctable td{padding:7px 9px;text-align:right;border-bottom:1px solid var(--line2);white-space:nowrap}
.ctable th:first-child,.ctable td:first-child{text-align:left;position:sticky;left:0;background:var(--panel)}
.ctable th{font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--faint);font-weight:600;border-bottom:1px solid var(--line)}
.ctable td.num{font-family:var(--mono)}
.tablewrap{overflow:auto;max-width:100%}
.ctable tbody tr:hover td{background:#f6f9f8}
.selrow{display:flex;gap:9px;flex-wrap:wrap;align-items:center;margin-bottom:13px}
.selrow label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;font-weight:600}
select.pick{border:1px solid var(--line);border-radius:8px;padding:7px 10px;font-size:13px;background:#fff;font-family:var(--sans);color:var(--text);max-width:360px}
.empty{padding:34px;text-align:center;color:var(--faint);font-size:13px}
.hint{font-size:11.5px;color:var(--faint);margin-top:9px;font-family:var(--mono)}
.callout{background:#fff;border:1px solid var(--line);border-left:3px solid var(--economy);border-radius:9px;padding:11px 14px;font-size:12.5px;color:var(--muted);margin-bottom:16px}
.callout b{color:var(--text)}
.prov h3{font-size:13px;margin:18px 0 8px}
.prov code{font-family:var(--mono);font-size:11.5px;background:var(--paper);padding:1px 5px;border-radius:4px}
.prov ul{margin:6px 0;padding-left:18px}.prov li{margin:5px 0;font-size:12.5px;color:var(--muted)}.prov li b{color:var(--text)}
.flagrow{display:flex;gap:8px;font-size:12px;padding:5px 0;border-bottom:1px solid var(--line2)}
.flagrow .fp{font-family:var(--mono);color:var(--equality);min-width:62px;text-align:right;font-weight:600}
.svgchart{width:100%;height:auto;display:block}
.tip{position:fixed;pointer-events:none;z-index:90;background:var(--ink);color:#fff;border-radius:8px;padding:7px 10px;font-size:12px;box-shadow:0 6px 18px #0006;max-width:260px;display:none}
.tip .tn{font-weight:600;margin-bottom:3px}.tip .tv{font-family:var(--mono)}
.mark{cursor:pointer}
.bar:hover,.dot:hover,.cpath:hover{opacity:.8}
.cpath{stroke:#fff;stroke-width:.4;cursor:pointer}
.cpath.sel{stroke:var(--ink);stroke-width:1.1}
.band{fill:transparent;cursor:crosshair}
.band:hover{fill:#0f766e0c}
::-webkit-scrollbar{width:9px;height:9px}::-webkit-scrollbar-thumb{background:#cdd6d1;border-radius:5px}
@media(max-width:760px){.app{grid-template-columns:1fr}.side{position:static;height:auto;flex-direction:row;overflow:auto}.nav{display:flex;gap:4px}.nav .grp,.side .foot,.brand .sub{display:none}}
</style>
</head>
