     <li><b>Choropleth</b>: Wert je ISO-3 im gewählten Jahr; Farbe = Quantil-Skala live aus Jahres-Werten; „keine Daten" = grau.</li></ul>
     <h3>Labels & Einheiten</h3><ul><li>Anzeigelabel = CSV-Spalte ohne World-Bank-/SDG-Code-Suffix. Werte 1:1. Einheit aus dem Spaltennamen; sonst „Einheit unbekannt" (z. B. <code>Pupil-teacher ratio</code>, <code>Population, total</code>).</li></ul>`,true);
  h+=`<div style="margin-top:16px">`+panel('Datenqualität — geflaggt, nicht bereinigt','','',
    flags.map(f=>`<div class="flagrow"><span class="fp">${f[0]}</span><span>${esc(f[1])}</span></div>`).join(''),true)+`</div>`;
  let tbl=`<div class="tablewrap"><table class="ctable"><thead><tr><th>Indikator (bereinigt)</th><th style="text-align:left">Einheit</th><th style="text-align:left">Thema</th><th>Fehlend %</th></tr></thead><tbody>`;
  B.meta.forEach(m=>{tbl+=`<tr><td>${esc(m.label)}</td><td style="text-align:left">${esc(u(m))}</td><td style="text-align:left"><span style="display:inline-flex;align-items:center;gap:6px"><span style="width:8px;height:8px;border-radius:2px;background:${TCHEX[m.theme]}"></span>${THEMES[m.theme]}</span></td><td class="num">${B.missPct[m.k]} %</td></tr>`;});
  tbl+=`</tbody></table></div>`;
  h+=`<div style="margin-top:16px">`+panel('Alle 47 Messgrößen · Einheit · Thema · Fehlend %','','',tbl,true)+`</div></div>`;
  return h;
}

// ---------- render ----------
const VIEWS={overview:{t:'Übersicht',c:'var(--accent)',sub:'Globale Kernindikatoren aller fünf Themenfelder auf einen Blick'},
  climate:{t:THEMES.climate,c:TCHEX.climate,sub:'Emissionen, erneuerbare Energie, Ressourcen & Naturkapital'},
  economy:{t:THEMES.economy,c:TCHEX.economy,sub:'Wirtschaftsleistung, Handel, Finanzsystem & Gründungskosten'},
  social:{t:THEMES.social,c:TCHEX.social,sub:'Gesundheit, Versorgung, Konnektivität & Bevölkerung'},
  education:{t:THEMES.education,c:TCHEX.education,sub:'Einschulung, Abschlüsse & Bildungssystem'},
  equality:{t:THEMES.equality,c:TCHEX.equality,sub:'Teilhabe, Recht, Arbeitsmarkt & Ungleichheit'},
  provenance:{t:'Datenherkunft',c:'var(--ink)',sub:'Quellnachweis: Felder, Aggregationen, Qualitäts-Flags'}};

function renderNav(){
  const nav=document.getElementById('nav');
  const b=(id,label,dot)=>`<button data-view="${id}" class="${S.view===id?'active':''}"><span class="dot" style="background:${dot}"></span>${esc(label)}</button>`;
  nav.innerHTML=b('overview','Übersicht','var(--accent)')+
    `<div class="grp">Themenfelder</div>`+b('climate',THEMES.climate,TCHEX.climate)+b('economy',THEMES.economy,TCHEX.economy)+
    b('social',THEMES.social,TCHEX.social)+b('education',THEMES.education,TCHEX.education)+b('equality',THEMES.equality,TCHEX.equality)+
    `<div class="grp">Meta</div>`+b('provenance','Datenherkunft','#fff');
}
function renderHead(){
  const v=VIEWS[S.view];
  document.getElementById('head').innerHTML=`<h2 class="vtitle"><span class="stripe" style="background:${v.c}"></span>${esc(v.t)}</h2><div class="vsub">${esc(v.sub)}</div>`;
}
function renderFilters(){
  const f=document.getElementById('filters');
  if(S.view==='provenance'){f.innerHTML='';return;}
  const [a,b]=S.yr, lo=(a-YMIN)/(YMAX-YMIN)*100, hi=(b-YMIN)/(YMAX-YMIN)*100;
  const dirty=a!==YMIN||b!==YMAX||S.countries.length||S.group;
  let chips='';
  if(S.countries.length){chips='<div class="chips">'+S.countries.slice(0,6).map(c=>`<span class="chip"><b>${esc(B.countries[c].name)}</b><button data-rm="${c}">×</button></span>`).join('')+(S.countries.length>6?`<span class="chip"><b>+${S.countries.length-6}</b></span>`:'')+'</div>';}
  const grp=(dim,val,label)=>{const on=S.group&&S.group.dim===dim&&S.group.val===val;return `<button class="gbtn${on?' on':''}" data-grp="${dim}|${val}">${esc(label)}</button>`;};
  f.innerHTML=`<div class="filters">
    <div class="fbox yearwrap"><div class="lab">Zeitraum (Jahr)</div><div class="rangeline">
      <span class="num" id="yLo">${a}</span>
      <div class="dual"><div class="track"></div><div class="fill" id="yFill" style="left:${lo}%;width:${hi-lo}%"></div>
      <input type="range" id="rLo" min="${YMIN}" max="${YMAX}" value="${a}"><input type="range" id="rHi" min="${YMIN}" max="${YMAX}" value="${b}"></div>
      <span class="num" id="yHi">${b}</span></div></div>
    <div class="fbox" style="position:relative"><div class="lab">Länder (${S.countries.length?S.countries.length+' gewählt':'alle'})</div>
      <button class="selectbtn" id="cBtn">${S.countries.length?S.countries.length+' Länder':'Alle Länder'} <span style="color:var(--faint)">▾</span></button>${chips}
      ${S.pop?popoverHTML():''}</div>
    <div class="fbox" style="flex:1 1 320px"><div class="lab">Schnellgruppen (Kontinent · Einkommen)</div><div class="groupbtns">
      ${CONTINENTS.map(c=>grp('continent',c,c)).join('')}<span style="width:1px;background:var(--line);margin:0 3px"></span>${INCOMES.map(i=>grp('income',i,i.replace(' income',''))).join('')}</div></div>
    <button class="resetbtn" id="reset" style="opacity:${dirty?1:.5}">Filter zurücksetzen</button>
  </div>`;
  if(S.pop){const s=document.getElementById('cSearch'); if(s){s.focus(); s.setSelectionRange(s.value.length,s.value.length);}}
}
function popoverHTML(){
  const list=COUNTRIES.filter(c=>c.name.toLowerCase().includes(S.q.toLowerCase()));
  return `<div class="popover" id="pop"><input class="search" id="cSearch" placeholder="Land suchen…" value="${esc(S.q)}">
    <ul class="optlist">${list.map(c=>`<li data-opt="${c.code}"><input type="checkbox" ${S.countries.includes(c.code)?'checked':''}> ${esc(c.name)}</li>`).join('')||'<li style="color:var(--faint)">Kein Treffer</li>'}</ul>
    ${S.countries.length?`<button class="gbtn" id="clearC" style="margin-top:8px;width:100%">Auswahl leeren</button>`:''}</div>`;
}
function renderContent(){
  const c=document.getElementById('content');
  if(S.view==='overview')c.innerHTML=viewOverview();
  else if(S.view==='provenance')c.innerHTML=viewProvenance();
  else c.innerHTML=viewTheme(S.view);
}
function renderAll(){renderNav();renderHead();renderFilters();renderContent();}

// ---------- events ----------
document.getElementById('nav').addEventListener('click',e=>{const b=e.target.closest('button[data-view]');if(!b)return;S.view=b.dataset.view;S.pop=false;renderAll();});

document.getElementById('filters').addEventListener('input',e=>{
  if(e.target.id==='rLo'){let v=Math.min(+e.target.value,S.yr[1]);S.yr=[v,S.yr[1]];updateSlider();renderContent();}
  if(e.target.id==='rHi'){let v=Math.max(+e.target.value,S.yr[0]);S.yr=[S.yr[0],v];updateSlider();renderContent();}
  if(e.target.id==='cSearch'){S.q=e.target.value;const pop=document.getElementById('pop');
    const list=COUNTRIES.filter(c=>c.name.toLowerCase().includes(S.q.toLowerCase()));
    pop.querySelector('.optlist').innerHTML=list.map(c=>`<li data-opt="${c.code}"><input type="checkbox" ${S.countries.includes(c.code)?'checked':''}> ${esc(c.name)}</li>`).join('')||'<li style="color:var(--faint)">Kein Treffer</li>';}
});
function updateSlider(){const[a,b]=S.yr,lo=(a-YMIN)/(YMAX-YMIN)*100,hi=(b-YMIN)/(YMAX-YMIN)*100;
  document.getElementById('yLo').textContent=a;document.getElementById('yHi').textContent=b;
  const fill=document.getElementById('yFill');fill.style.left=lo+'%';fill.style.width=(hi-lo)+'%';
  document.getElementById('rLo').value=a;document.getElementById('rHi').value=b;}

document.getElementById('filters').addEventListener('click',e=>{
  const t=e.target;
  if(t.closest('#cBtn')){S.pop=!S.pop;renderFilters();return;}
  const rm=t.closest('[data-rm]'); if(rm){toggleCountry(rm.dataset.rm);return;}
  const opt=t.closest('[data-opt]'); if(opt){const code=opt.dataset.opt;S.countries=S.countries.includes(code)?S.countries.filter(x=>x!==code):[...S.countries,code];renderFilters();renderContent();return;}
  if(t.id==='clearC'){S.countries=[];renderFilters();renderContent();return;}
  const g=t.closest('[data-grp]'); if(g){const[dim,val]=g.dataset.grp.split('|');const on=S.group&&S.group.dim===dim&&S.group.val===val;S.group=on?null:{dim,val};renderFilters();renderContent();return;}
  if(t.id==='reset'){S.yr=[YMIN,YMAX];S.countries=[];S.group=null;S.pop=false;renderFilters();renderContent();return;}
});
document.addEventListener('mousedown',e=>{ if(S.pop && !e.target.closest('#pop') && !e.target.closest('#cBtn')){S.pop=false;renderFilters();}});

// content control selects + chart interactions
document.getElementById('content').addEventListener('change',e=>{
  const sel=e.target.closest('select[data-ctl]'); if(!sel)return;
  const id=sel.dataset.ctl; S.ctrl[id]=sel.dataset.ctl==='ov_mapY'?+sel.value:sel.value;
  if(id==='ov_mapY')S.ctrl[id]=+sel.value;
  renderContent();
});
document.getElementById('content').addEventListener('click',e=>{
  const mk=e.target.closest('.mark[data-code]'); if(mk){toggleCountry(mk.dataset.code);}
});
// tooltips (delegated mousemove)
document.getElementById('content').addEventListener('mousemove',e=>{
  const bar=e.target.closest('.bar[data-code]');
  const dot=e.target.closest('.dot[data-code]');
  const cp=e.target.closest('.cpath[data-code]');
  const band=e.target.closest('.band[data-chart]');
  if(bar){const m=mByKey[curRankKey()];tipShow(`<div class="tn">${esc(bar.dataset.name)}</div><div class="tv">${esc(fmt(+bar.dataset.val,m?m.unit:null))}</div>`,e);return;}
  if(dot){const r=CHARTREG['sc'];const z=dot.dataset.z;
    tipShow(`<div class="tn">${esc(dot.dataset.name)}</div><div class="tv">${esc(r.mx.label)}: ${esc(fmt(+dot.dataset.x,r.mx.unit))}</div><div class="tv">${esc(r.my.label)}: ${esc(fmt(+dot.dataset.y,r.my.unit))}</div>${z!=null&&r.ms?`<div class="tv">${esc(r.ms.label)}: ${esc(fmt(+z,r.ms.unit))}</div>`:''}`,e);return;}
  if(cp){const r=CHARTREG['map'];const val=cp.dataset.val;
    tipShow(`<div class="tn">${esc(cp.dataset.name)}</div><div class="tv">${val===''?'keine Daten':esc(fmt(+val,r.m.unit))+(r.m.unit==='%'?' %':'')}</div>`,e);return;}
  if(band){const r=CHARTREG[band.dataset.chart];if(!r){tipHide();return;}const y=+band.dataset.year;
    let html=`<div class="tn">${y}</div>`;r.series.forEach(s=>{const p=s.points.find(pp=>pp.x===y);const val=p?p.y:null;
      html+=`<div class="tv" style="color:${s.color}">${esc(s.name)}: ${val==null?'keine Daten':esc(fmt(val,r.m.unit))}</div>`;});
    tipShow(html,e);return;}
  tipHide();
});
document.getElementById('content').addEventListener('mouseleave',tipHide);
function curRankKey(){ return S.view==='overview'?S.ctrl['ov_rank']:S.ctrl[S.view+'_rank']; }

renderAll();
</script>
</body>
</html>
