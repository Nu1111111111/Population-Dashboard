<script>
"use strict";
const B = JSON.parse(document.getElementById('bundle').textContent);
const MAP = JSON.parse(document.getElementById('mapdata').textContent);
const mByKey = {}; B.meta.forEach(m=>mByKey[m.k]=m);
const byLabel = {}; B.meta.forEach(m=>byLabel[m.label]=m);
const K = lbl => byLabel[lbl].k;
const THEMES={climate:'Klima & Energie',economy:'Wirtschaft & Finanzen',social:'Soziales & Entwicklung',education:'Bildung',equality:'Gleichstellung & Governance'};
const TCHEX={climate:'#2E7D5B',economy:'#B7791F',social:'#2B7C8C',education:'#6B5BA6',equality:'#B0476B'};
const CONT={'Africa':'#B7791F','Asia':'#2B7C8C','Europe':'#6B5BA6','North America':'#2E7D5B','South America':'#B0476B','Oceania':'#0F766E'};
const SERIES=['#0F766E','#B7791F','#6B5BA6','#B0476B','#2E7D5B','#2B7C8C','#8a4f9e','#c2603f'];
const ROWS = B.rows.map(r=>{const[code,year,income,regime,v]=r;const c=B.countries[code];return{code,year,income,regime,name:c.name,continent:c.continent,region:c.region,v};});
const COUNTRIES = Object.keys(B.countries).map(code=>({code,...B.countries[code]})).sort((a,b)=>a.name.localeCompare(b.name));
const YEARS=B.years, YMIN=YEARS[0], YMAX=YEARS[YEARS.length-1];
const CONTINENTS=[...new Set(COUNTRIES.map(c=>c.continent).filter(Boolean))].sort();
const INCOMES=['Low income','Lower-middle income','Upper-middle income','High income'];
const esc = s => String(s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

// ---------- format ----------
function fmt(v,unit){
  if(v==null||Number.isNaN(v))return null;
  const a=Math.abs(v);
  if(unit==='current US$'||unit==='million tonnes'||a>=1e6){
    if(a>=1e12)return (v/1e12).toFixed(2)+'\u202FT';
    if(a>=1e9)return (v/1e9).toFixed(2)+'\u202FB';
    if(a>=1e6)return (v/1e6).toFixed(2)+'\u202FM';
    if(a>=1e3)return (v/1e3).toFixed(1)+'\u202Fk';
  }
  if(a>=1000)return v.toLocaleString('de-DE',{maximumFractionDigits:0});
  if(a>=100)return v.toFixed(0);
  if(a>=10)return v.toFixed(1);
  return v.toFixed(2);
}
const u = m => m.unit||'Einheit unbekannt';
const NDt = '<span class="nodata-tag">keine Daten</span>';
function mean(a){const x=a.filter(v=>v!=null&&!Number.isNaN(v));return x.length?x.reduce((s,b)=>s+b,0)/x.length:null;}
function sumv(a){const x=a.filter(v=>v!=null&&!Number.isNaN(v));return x.length?x.reduce((s,b)=>s+b,0):null;}

// ---------- state ----------
const S={view:'overview',yr:[YMIN,YMAX],countries:[],group:null,pop:false,q:'',ctrl:{}};
function ctrl(key,def){ if(!(key in S.ctrl)) S.ctrl[key]=def; return S.ctrl[key]; }
function filtered(){
  return ROWS.filter(r=>{
    if(r.year<S.yr[0]||r.year>S.yr[1])return false;
    if(S.countries.length&&!S.countries.includes(r.code))return false;
    if(S.group){const g=S.group;
      if(g.dim==='continent'&&r.continent!==g.val)return false;
      if(g.dim==='income'&&r.income!==g.val)return false;}
    return true;
  });
}
function toggleCountry(code){
  S.countries = S.countries.includes(code)?S.countries.filter(x=>x!==code):[...S.countries,code];
  renderFilters(); renderContent();
}

// ---------- scales / ticks ----------
function niceTicks(min,max,n){
  if(min===max){min-=1;max+=1;}
  const span=max-min, step0=span/n, mag=Math.pow(10,Math.floor(Math.log10(step0)));
  const norm=step0/mag; let step;
  step=(norm<1.5?1:norm<3?2:norm<7?5:10)*mag;
  const t0=Math.floor(min/step)*step, ts=[];
  for(let v=t0;v<=max+step*0.5;v+=step) ts.push(+v.toFixed(10));
  return ts.filter(t=>t>=min-step*0.001&&t<=max+step*0.001);
}
function tipShow(html,e){const t=document.getElementById('tip');t.innerHTML=html;t.style.display='block';t.style.left=(e.clientX+14)+'px';t.style.top=(e.clientY+14)+'px';}
function tipHide(){document.getElementById('tip').style.display='none';}

// ---------- LINE CHART ----------
let chartSeq=0;
const CHARTREG={};
function lineChart(series, m, opts){
  opts=opts||{};
  const W=720,H=250,ml=58,mr=16,mt=10,mb=26, iw=W-ml-mr, ih=H-mt-mb;
  const years=YEARS.filter(y=>y>=S.yr[0]&&y<=S.yr[1]);
  let vals=[]; series.forEach(s=>s.points.forEach(p=>{if(p.y!=null)vals.push(p.y);}));
  if(!vals.length) return '<div class="empty">keine Daten im Filter</div>';
  let mn=Math.min(...vals), mx=Math.max(...vals); if(mn>0&&mn/mx<0.4)mn=Math.min(0,mn);
  const yt=niceTicks(mn,mx,5); mn=Math.min(mn,yt[0]); mx=Math.max(mx,yt[yt.length-1]);
  const xs=y=>ml+(years.length<2?iw/2:(y-years[0])/(years[years.length-1]-years[0])*iw);
  const ys=v=>mt+ih-(v-mn)/((mx-mn)||1)*ih;
  const id='c'+(chartSeq++);
  let g='';
  yt.forEach(t=>{const yy=ys(t);g+=`<line x1="${ml}" y1="${yy.toFixed(1)}" x2="${W-mr}" y2="${yy.toFixed(1)}" stroke="var(--grid)"/>`+
    `<text x="${ml-7}" y="${(yy+3).toFixed(1)}" text-anchor="end" font-size="10" fill="var(--muted)" font-family="var(--mono)">${esc(fmt(t,m.unit))}</text>`;});
  years.forEach((y,i)=>{ if(years.length<=12||i%2===0) g+=`<text x="${xs(y).toFixed(1)}" y="${H-8}" text-anchor="middle" font-size="10" fill="var(--muted)">${y}</text>`;});
  series.forEach(s=>{
    let d='',pen=false;
    s.points.forEach(p=>{ if(p.y==null){pen=false;return;} const X=xs(p.x).toFixed(1),Y=ys(p.y).toFixed(1); d+=(pen?'L':'M')+X+' '+Y+' '; pen=true; });
    g+=`<path d="${d}" fill="none" stroke="${s.color}" stroke-width="${s.w||2}"/>`;
    s.points.forEach(p=>{ if(p.y!=null) g+=`<circle cx="${xs(p.x).toFixed(1)}" cy="${ys(p.y).toFixed(1)}" r="2.2" fill="${s.color}"/>`;});
  });
  // hover bands
  CHARTREG[id]={series,m,years};
  years.forEach(y=>{ const bw=iw/Math.max(1,years.length); const bx=xs(y)-bw/2;
    g+=`<rect class="band" data-chart="${id}" data-year="${y}" x="${bx.toFixed(1)}" y="${mt}" width="${bw.toFixed(1)}" height="${ih}"/>`;});
  return `<svg class="svgchart" viewBox="0 0 ${W} ${H}" data-line="1">${g}</svg>`;
}

// ---------- HORIZONTAL BAR ----------
function barChart(data, m, opts){
  opts=opts||{};
  if(!data.length) return '<div class="empty">keine Daten</div>';
  const rowH=22, W=720, ml=130, mr=50, mt=4, mb=22, ih=data.length*rowH, H=mt+ih+mb, iw=W-ml-mr;
  let mx=Math.max(...data.map(d=>d.val)), mn=Math.min(0,...data.map(d=>d.val));
  const xt=niceTicks(mn,mx,5); mx=Math.max(mx,xt[xt.length-1]); mn=Math.min(mn,xt[0]);
  const xs=v=>ml+(v-mn)/((mx-mn)||1)*iw;
  let g='';
  xt.forEach(t=>{const X=xs(t);g+=`<line x1="${X.toFixed(1)}" y1="${mt}" x2="${X.toFixed(1)}" y2="${mt+ih}" stroke="var(--grid)"/>`+
    `<text x="${X.toFixed(1)}" y="${H-7}" text-anchor="middle" font-size="9.5" fill="var(--muted)" font-family="var(--mono)">${esc(fmt(t,m.unit))}</text>`;});
  const x0=xs(0);
  data.forEach((d,i)=>{ const y=mt+i*rowH+3, bh=rowH-7; const X=xs(d.val);
    const bx=Math.min(x0,X), bw=Math.abs(X-x0);
    g+=`<rect class="bar mark" data-code="${d.code}" data-name="${esc(d.name)}" data-val="${d.val}" x="${bx.toFixed(1)}" y="${y}" width="${Math.max(0.5,bw).toFixed(1)}" height="${bh}" rx="2" fill="${d.fill}"/>`+
       `<text x="${(ml-8)}" y="${y+bh/2+3.5}" text-anchor="end" font-size="10.5" fill="var(--text)">${esc(d.name.length>20?d.name.slice(0,19)+'…':d.name)}</text>`+
       `<text x="${(X+(d.val>=0?4:-4)).toFixed(1)}" y="${y+bh/2+3.5}" text-anchor="${d.val>=0?'start':'end'}" font-size="9.5" fill="var(--muted)" font-family="var(--mono)">${esc(fmt(d.val,m.unit))}</text>`;});
  return `<svg class="svgchart" viewBox="0 0 ${W} ${H}">${g}</svg>`;
}

// ---------- SCATTER ----------
function scatterChart(pts, mx_, my_, ms_, opts){
  opts=opts||{};
  if(!pts.length) return '<div class="empty">keine gemeinsamen Datenpunkte</div>';
  const W=720,H=320,ml=60,mr=18,mt=12,mb=46,iw=W-ml-mr,ih=H-mt-mb;
  let xmin=Math.min(...pts.map(p=>p.x)),xmax=Math.max(...pts.map(p=>p.x));
  let ymin=Math.min(...pts.map(p=>p.y)),ymax=Math.max(...pts.map(p=>p.y));
  const xt=niceTicks(xmin,xmax,5),ytk=niceTicks(ymin,ymax,5);
  xmin=Math.min(xmin,xt[0]);xmax=Math.max(xmax,xt[xt.length-1]);ymin=Math.min(ymin,ytk[0]);ymax=Math.max(ymax,ytk[ytk.length-1]);
  const xs=v=>ml+(v-xmin)/((xmax-xmin)||1)*iw, ys=v=>mt+ih-(v-ymin)/((ymax-ymin)||1)*ih;
  let zmin=Infinity,zmax=-Infinity; if(ms_){pts.forEach(p=>{zmin=Math.min(zmin,p.z);zmax=Math.max(zmax,p.z);});}
  const rad=z=>{ if(!ms_||zmax===zmin)return 4; return 3+Math.sqrt((z-zmin)/(zmax-zmin))*11; };
  let g='';
  ytk.forEach(t=>{const Y=ys(t);g+=`<line x1="${ml}" y1="${Y.toFixed(1)}" x2="${W-mr}" y2="${Y.toFixed(1)}" stroke="var(--grid)"/>`+
    `<text x="${ml-7}" y="${(Y+3).toFixed(1)}" text-anchor="end" font-size="9.5" fill="var(--muted)" font-family="var(--mono)">${esc(fmt(t,my_.unit))}</text>`;});
  xt.forEach(t=>{const X=xs(t);g+=`<line x1="${X.toFixed(1)}" y1="${mt}" x2="${X.toFixed(1)}" y2="${mt+ih}" stroke="var(--grid)"/>`+
    `<text x="${X.toFixed(1)}" y="${mt+ih+14}" text-anchor="middle" font-size="9.5" fill="var(--muted)" font-family="var(--mono)">${esc(fmt(t,mx_.unit))}</text>`;});
  g+=`<text x="${ml+iw/2}" y="${H-6}" text-anchor="middle" font-size="10.5" fill="var(--muted)">${esc(mx_.label)}${mx_.unit?' ('+esc(mx_.unit)+')':''}</text>`;
  const sel=S.countries;
  pts.forEach(p=>{ const on=sel.includes(p.code); const op=(sel.length&&!on)?0.28:0.8;
    g+=`<circle class="dot mark" data-code="${p.code}" data-name="${esc(p.name)}" data-x="${p.x}" data-y="${p.y}"${ms_?` data-z="${p.z}"`:''} cx="${xs(p.x).toFixed(1)}" cy="${ys(p.y).toFixed(1)}" r="${rad(p.z).toFixed(1)}" fill="${CONT[p.continent]||'#0F766E'}" fill-opacity="${op}" stroke="${on?'#0E1A17':'none'}" stroke-width="${on?2:0}"/>`;});
  CHARTREG['sc']={mx:mx_,my:my_,ms:ms_};
  return `<svg class="svgchart" viewBox="0 0 ${W} ${H}" data-scatter="1">${g}</svg>`;
}

// ---------- CHOROPLETH ----------
const SEQ=['#e6efe9','#bfe0d4','#8fcab6','#5bb097','#2E8B6F','#1d6e54','#114b3a'];
function choropleth(mkey, year){
  const m=mByKey[mkey];
  const valByCode={}; ROWS.forEach(r=>{if(r.year===year)valByCode[r.code]=r.v[mkey];});
  const fr=filtered(); const inF=new Set(fr.filter(r=>r.year===year).map(r=>r.code)); const noFilter=fr.length===0||(!S.countries.length&&!S.group);
  const v=Object.values(valByCode).filter(x=>x!=null).sort((a,b)=>a-b);
  const qs=SEQ.map((_,i)=>v.length?v[Math.floor(i/SEQ.length*v.length)]:null);
  const col=x=>{if(x==null)return 'var(--nodata)';let i=0;while(i<qs.length-1&&x>=qs[i+1])i++;return SEQ[i];};
  let g='';
  Object.keys(MAP.paths).forEach(code=>{ const val=valByCode[code]; const active=noFilter||inF.has(code);
    g+=`<path class="cpath mark${S.countries.includes(code)?' sel':''}" data-code="${code}" data-name="${esc(B.countries[code]?B.countries[code].name:code)}" data-val="${val==null?'':val}" d="${MAP.paths[code]}" fill="${col(val)}" opacity="${active?1:0.25}"/>`;});
  CHARTREG['map']={m};
  let leg='<div class="legend"><span class="lt">gering</span>';
  SEQ.forEach((c,i)=>leg+=`<div class="sw" style="background:${c}" title="${qs[i]!=null?esc(fmt(qs[i],m.unit)):''}"></div>`);
  leg+='<span class="lt">hoch</span><span class="sw" style="background:var(--nodata);margin-left:10px"></span><span class="lt">keine Daten</span></div>';
  return `<svg class="svgchart" viewBox="0 0 ${MAP.w} ${MAP.h}" data-map="1" style="background:#f4f7f6;border-radius:8px">${g}</svg>`+leg;
}

// ---------- coverage ----------
function coverage(rows,mkey){const tot=rows.length,have=rows.filter(r=>r.v[mkey]!=null).length,p=tot?Math.round(100*have/tot):0;
  return `<div class="cov"><span>Abdeckung</span><div class="covbar"><i style="width:${p}%"></i></div><span>${have}/${tot} · ${p}%</span></div>`;}

// ---------- helpers to build chart data ----------
function lineSeries(rows,mkey,codes,agg){
  const years=YEARS.filter(y=>y>=S.yr[0]&&y<=S.yr[1]);
  if(codes&&codes.length){
    return codes.map((c,i)=>({name:B.countries[c].name,color:SERIES[i%8],
      points:years.map(y=>{const r=rows.find(rr=>rr.year===y&&rr.code===c);return{x:y,y:r?(r.v[mkey]??null):null};})}));
  }
  const m=mByKey[mkey];
  return [{name:(agg==='sum'?'Summe':'Mittel')+' (gefiltert)',color:TCHEX[m.theme]||'#0F766E',w:2.4,
    points:years.map(y=>{const vv=rows.filter(r=>r.year===y).map(r=>r.v[mkey]);return{x:y,y:agg==='sum'?sumv(vv):mean(vv)};})}];
}
function rankData(rows,mkey,year,n,asc){
  const a=rows.filter(r=>r.year===year&&r.v[mkey]!=null).map(r=>({code:r.code,name:B.countries[r.code].name,val:r.v[mkey],
    fill:S.countries.includes(r.code)?'#0E1A17':(CONT[r.continent]||'#0F766E')}));
  a.sort((x,y)=>asc?x.val-y.val:y.val-x.val); return a.slice(0,n);
}
function scatterData(rows,xk,yk,year,zk){
  return rows.filter(r=>r.year===year&&r.v[xk]!=null&&r.v[yk]!=null)
    .map(r=>({code:r.code,name:B.countries[r.code].name,x:r.v[xk],y:r.v[yk],z:zk?(r.v[zk]??1):1,continent:r.continent}));
}
function pickHTML(id,keys,sel){return `<select class="pick" data-ctl="${id}">`+keys.map(k=>`<option value="${k}"${k===sel?' selected':''}>${esc(mByKey[k].label)}</option>`).join('')+`</select>`;}

